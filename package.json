{
  "name": "omniforge-ai-engine",
  "version": "13.0.0",
  "description": "Pipeline industrial de generacion de video con IA — Google Imagen, Gemini, OpenRouter, Json2Video",
  "author": "OmniForge Team",
  "license": "MIT",
  "main": "server.js",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:debug": "node --inspect server.js",
    "logs": "tail -f omni_audit.log",
    "logs:clear": "echo '' > omni_audit.log && echo 'Log cleared'",
    "check": "node --check server.js && echo 'Syntax OK'",
    "health": "curl -s http://localhost:3000/health | node -e \"process.stdin.resume();let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>console.log(JSON.parse(d)))\"",
    "test:imagen": "node -e \"const axios=require('axios');axios.post('http://localhost:3000/generate',{text:'test gato',numEscenas:1}).then(r=>console.log(r.data)).catch(e=>console.error(e.message))\"",
    "clean": "node -e \"require('fs').readdirSync('tmp').forEach(f=>require('fs').unlinkSync('tmp/'+f))\" 2>/dev/null || echo 'Nothing to clean'",
    "size": "wc -l server.js index.html && du -sh .",
    "tunnel": "npx localtunnel --port 3000 --subdomain omniforge-ai",
    "update-check": "npm outdated"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "~7.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "nodemonConfig": {
    "watch": [
      "server.js"
    ],
    "ext": "js",
    "ignore": [
      "omni_audit.log",
      "tmp/",
      "node_modules/"
    ],
    "delay": "500",
    "env": {
      "NODE_ENV": "development"
    }
  },
  "keywords": [
    "ai",
    "video-generation",
    "google-imagen",
    "gemini",
    "json2video",
    "pollinations",
    "imgbb",
    "openrouter",
    "gpt4",
    "text-to-video",
    "node",
    "express",
    "pipeline",
    "cinematic",
    "tts",
    "azure-voice",
    "beat-sync",
    "ken-burns",
    "color-grading",
    "omniforge"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tu-usuario/omniforge-ai-engine"
  },
  "bugs": {
    "url": "https://github.com/tu-usuario/omniforge-ai-engine/issues"
  },
  "homepage": "http://localhost:3000",
  "config": {
    "port": "3000",
    "log_file": "omni_audit.log",
    "tmp_dir": "tmp",
    "max_scenes": "10",
    "img_delay_ms": "5000",
    "version_label": "v12.0.0-ULTRA"
  },
  "omniforge": {
    "pipeline": {
      "text_models": [
        "openai/gpt-4o-mini",
        "google/gemini-2.0-flash-lite-001",
        "mistralai/mistral-small-3.1-24b-instruct:free"
      ],
      "image_sources": [
        "aiml-api (qwen / flux)",
        "google-imagen-4.0",
        "pollinations-flux",
        "pollinations-turbo",
        "pollinations-flux-realism",
        "pollinations-flux-anime",
        "pollinations-flux-cablyai",
        "unsplash-source",
        "loremflickr",
        "picsum"
      ],
      "visual_styles": [
        "cinematic",
        "anime",
        "documentary",
        "cyberpunk",
        "fantasy",
        "vintage"
      ],
      "transition_packs": [
        "cinematic",
        "dynamic",
        "smooth",
        "random"
      ],
      "voices_available": [
        "es-MX-DaliaNeural",
        "es-MX-JorgeNeural",
        "es-ES-ElviraNeural",
        "es-ES-AlvaroNeural",
        "es-CO-SalomeNeural",
        "en-US-JennyNeural"
      ],
      "output_formats": [
        {
          "id": "portrait",
          "resolution": "720x1280",
          "ratio": "9:16",
          "platform": "TikTok/Reels"
        },
        {
          "id": "landscape",
          "resolution": "1280x720",
          "ratio": "16:9",
          "platform": "YouTube"
        },
        {
          "id": "square",
          "resolution": "1080x1080",
          "ratio": "1:1",
          "platform": "Instagram"
        }
      ],
      "fps_options": [
        24,
        30,
        60
      ],
      "max_scene_duration_sec": 12,
      "min_scene_duration_sec": 3,
      "new_features_v13": [
        "SQLite history database",
        "Job queue system",
        "Preview first scene",
        "Re-render individual scenes",
        "Templates system (6 default + custom)",
        "Chapter/acts structure",
        "Documentary shot types",
        "Karaoke-style subtitles",
        "Multi-voice narrator + character",
        "Dynamic music by scene intensity",
        "SFX on transitions",
        "Visual coherence seeds",
        "Prompt chaining",
        "Thumbnail generator",
        "Timeline drag-and-drop",
        "Inline subtitle editor",
        "History panel",
        "Templates panel",
        "3 themes (Neon/Industrial/Matrix)",
        "Swagger API docs",
        "Rate limiting",
        "Discord/Telegram webhook",
        "Queue indicator"
      ]
    },
    "features": {
      "ken_burns_zoom": true,
      "director_of_photography": true,
      "color_grading_lut": true,
      "hud_overlay": true,
      "lower_thirds": true,
      "parallax_simulation": true,
      "glitch_transition": true,
      "beat_sync_duration": true,
      "ab_prompt_testing": true,
      "sfx_ambient_layer": true,
      "auto_translation": true,
      "character_continuity": true,
      "intro_slate": true,
      "outro_credits": true,
      "discord_webhook": true,
      "sse_live_preview": true,
      "thumbnail_generator": true
    },
    "ui": {
      "cursor": "custom plasma trail",
      "background": "matrix rain + circuit paths + neural nodes",
      "logo_effect": "glitch + energy rings",
      "panels": "holographic sheen + corner brackets",
      "waveform": "22 bar animated visualizer",
      "stats_bar": "animated counters (videos, scenes, images, uptime)",
      "processing_panel": "energy beams + dna helix",
      "magnetic_button": true,
      "live_badge": true,
      "neon_signature": true,
      "footer_accent": true
    },
    "translations_supported": [
      "es",
      "en",
      "pt",
      "fr",
      "de",
      "ja"
    ],
    "beat_bpm_by_mood": {
      "epic": 138,
      "action": 160,
      "suspense": 80,
      "futuristic": 120,
      "calm": 72,
      "romantic": 90,
      "horror": 60,
      "documentary": 95
    }
  }
}
